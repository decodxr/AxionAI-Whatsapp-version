import fs from "fs";
import path from "path";
import { fileURLToPath } from "url";
import ffmpeg from "fluent-ffmpeg";
import ffmpegPath from "ffmpeg-static";
import { GoogleGenAI } from "@google/genai";

ffmpeg.setFfmpegPath(ffmpegPath);

const __filename = fileURLToPath(import.meta.url);
const __dirname = path.dirname(__filename);
const TMP_DIR = path.resolve(__dirname, "../tmp");
fs.mkdirSync(TMP_DIR, { recursive: true });

let geminiClient = null;

function getGeminiClient(apiKey) {
  if (!geminiClient) {
    geminiClient = new GoogleGenAI({ apiKey });
  }
  return geminiClient;
}

function pcmToOggOpus(pcmPath, outPath) {
  return new Promise((resolve, reject) => {
    ffmpeg()
      .input(pcmPath)
      .inputOptions(["-f s16le", "-ar 24000", "-ac 1"])
      .audioCodec("libopus")
      .audioBitrate("32k")
      .format("ogg")
      .save(outPath)
      .on("end", resolve)
      .on("error", reject);
  });
}

export async function synthesizeOggFromText({ apiKey, model, voiceName, text }) {
  const client = getGeminiClient(apiKey);

  const response = await client.models.generateContent({
    model,
    contents: [{ parts: [{ text: `Leia em português do Brasil, de forma natural e simpática: ${text}` }] }],
    config: {
      responseModalities: ["AUDIO"],
      speechConfig: {
        voiceConfig: {
          prebuiltVoiceConfig: {
            voiceName
          }
        }
      }
    }
  });

  const base64 = response?.candidates?.[0]?.content?.parts?.[0]?.inlineData?.data;
  if (!base64) {
    throw new Error("Gemini TTS não retornou áudio.");
  }

  const id = `${Date.now()}-${Math.random().toString(36).slice(2, 9)}`;
  const pcmPath = path.join(TMP_DIR, `${id}.pcm`);
  const oggPath = path.join(TMP_DIR, `${id}.ogg`);

  fs.writeFileSync(pcmPath, Buffer.from(base64, "base64"));
  await pcmToOggOpus(pcmPath, oggPath);
  const audioBuffer = fs.readFileSync(oggPath);

  fs.rmSync(pcmPath, { force: true });
  fs.rmSync(oggPath, { force: true });

  return audioBuffer;
}
